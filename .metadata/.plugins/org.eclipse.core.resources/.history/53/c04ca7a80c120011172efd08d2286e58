package com.dcl.sim;

import org.springframework.stereotype.Service;

@Service
public class SimService {
	
	private Sim sim;
	
	public SimService() {
		System.out.println("Sim service 0-param constructor");
	}
	
	public SimService(Sim sim) {
		this.sim=sim;
	}
	
	public void call() {
		sim.activate();
	}
	
}
